<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleDisplayName</key>
    <string>Resonance</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>写真とその瞬間の空気感を記録するためにカメラを使用します。</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>写真と一緒に環境音を保存するためにマイクを使用します。</string>
    <key>NSMotionUsageDescription</key>
    <string>端末の向きや空間情報を一緒に記録して、その場の空気感をより豊かに保存するために使用します。</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>その瞬間の空気感を場所と結びつけて記録するために位置情報を使用します。</string>
    <key>NSLocationTemporaryUsageDescriptionDictionary</key>
    <dict>
        <key>ResonancePreciseCapture</key>
        <string>撮影した瞬間を純正マップに近い精度で結びつけ、場所の記録精度を高めるために正確な位置情報を使用します。</string>
    </dict>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>録音した音声の内容を文字起こしして検索しやすくするために使用します。</string>
</dict>
</plist>
